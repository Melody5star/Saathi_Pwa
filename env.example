# ── साथी AI — Environment Variables ──
# Copy this file to .env.local for local dev
# Add all these to Vercel → Settings → Environment Variables

# ── Anthropic (Claude AI) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (User database) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...

# ── Dodo Payments (Automated payment + webhook) ──
# Get from: dodopayments.com → Dashboard → Webhooks
DODO_WEBHOOK_SECRET=whsec_...
# Payment page links — get from Dodo dashboard → Payment Links
DODO_LINK_99=https://checkout.dodopayments.com/buy/...    # founding ₹99
DODO_LINK_299=https://checkout.dodopayments.com/buy/...   # pro ₹299

# ── Gmail SMTP (Confirmation emails) ──
# Use: support@saathiai.health Google account
# App password: myaccount.google.com → Security → App Passwords
GMAIL_USER=support@saathiai.health
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Brevo (Feedback emails) ──
# Get from: brevo.com → API Keys
BREVO_API_KEY=xkeysib-...
